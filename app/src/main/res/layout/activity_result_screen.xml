<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FFFFFF">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Identification Result"
            android:background="?attr/colorPrimary"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="120dp"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <!-- Collage Image Container Placeholder -->
            <FrameLayout
                android:id="@+id/collageContainer"
                android:layout_width="match_parent"
                android:layout_height="200dp"
                android:layout_marginBottom="16dp" />

            <!-- Nickname input field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="16dp"
                android:hint="Nickname"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNickname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Plant Info Data Block -->
            <TextView android:text="Scientific Name" android:textColor="#888888" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvScientificName" android:textSize="18sp" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="8dp"/>

            <TextView android:text="Authorship" android:textColor="#888888" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvAuthorship" android:textSize="18sp" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="8dp"/>

            <TextView android:text="Family" android:textColor="#888888" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvFamily" android:textSize="18sp" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="8dp"/>

            <TextView android:text="Common Names" android:textColor="#888888" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvCommonNames" android:textSize="18sp" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#E0E0E0" android:layout_marginBottom="16dp"/>

            <!-- Notes input field -->
            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Notes"
                android:layout_marginBottom="20dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:minLines="3"
                    android:maxLines="5"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <!-- Reference Module Container -->
            <LinearLayout
                android:id="@+id/wikiSection"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical">
                <TextView
                    android:text="Reference Information"
                    android:textColor="#888888"
                    android:textStyle="bold"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_marginBottom="8dp"/>

                <com.google.android.material.card.MaterialCardView
                    android:id="@+id/wikiCard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    app:cardCornerRadius="12dp"
                    app:cardElevation="0dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="#E0E0E0">
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical">
                        <ImageView
                            android:id="@+id/ivWikiImage"
                            android:layout_width="match_parent"
                            android:layout_height="180dp"
                            android:scaleType="centerCrop"/>
                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:orientation="vertical"
                            android:padding="16dp">
                            <TextView
                                android:id="@+id/tvWikiSummary"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:textColor="#222222"
                                android:textSize="15sp"
                                android:lineSpacingMultiplier="1.2"/>
                            <TextView
                                android:id="@+id/btnWikiSource"
                                android:layout_width="wrap_content"
                                android:layout_height="wrap_content"
                                android:text="Source: Wikipedia"
                                android:textColor="#2196F3"
                                android:textStyle="bold"
                                android:layout_marginTop="12dp"
                                android:drawablePadding="4dp"/>
                        </LinearLayout>
                    </LinearLayout>
                </com.google.android.material.card.MaterialCardView>
            </LinearLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Action Bar containing Sticky Action Targets -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="#F5F5F5"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="15dp"
        android:paddingBottom="40dp"
        android:elevation="8dp">

        <Button
            android:id="@+id/btnSave"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Save Plant"
            android:layout_marginEnd="5dp"/>

        <Button
            android:id="@+id/btnDiscard"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Discard"
            android:layout_marginStart="5dp"/>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>