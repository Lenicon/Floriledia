<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout 
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/pastel_bg_blue">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:elevation="0dp"
        android:background="@android:color/transparent">
        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="Plant Details"
            app:titleTextColor="@color/pastel_slate_blue"
            android:background="@android:color/transparent"/>
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:paddingBottom="120dp"
        android:clipToPadding="false"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="16dp">

            <com.lenicon.floriledia.views.components.CollageLayout
                android:id="@+id/plantCollageView"
                android:layout_width="match_parent"
                android:layout_height="220dp"
                android:layout_marginBottom="16dp"
                android:background="#00000000" />

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                android:hint="Nickname"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNickname"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:inputType="textCapWords" />
            </com.google.android.material.textfield.TextInputLayout>

            <TextView android:text="Scientific Name" android:textColor="@color/pastel_slate_blue" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvScientificName" android:textSize="18sp" android:textColor="#333333" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#D1D9E6" android:layout_marginBottom="12dp"/>

            <TextView android:text="Authorship" android:textColor="@color/pastel_slate_blue" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvAuthorship" android:textSize="18sp" android:textColor="#333333" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#D1D9E6" android:layout_marginBottom="12dp"/>

            <TextView android:text="Family" android:textColor="@color/pastel_slate_blue" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvFamily" android:textSize="18sp" android:textColor="#333333" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#D1D9E6" android:layout_marginBottom="12dp"/>

            <TextView android:text="Common Names" android:textColor="@color/pastel_slate_blue" android:textStyle="bold" android:layout_width="match_parent" android:layout_height="wrap_content"/>
            <TextView android:id="@+id/tvCommonNames" android:textSize="18sp" android:textColor="#333333" android:layout_width="match_parent" android:layout_height="wrap_content" android:paddingVertical="4dp"/>
            <View android:layout_width="match_parent" android:layout_height="1dp" android:background="#D1D9E6" android:layout_marginBottom="24dp"/>

            <com.google.android.material.textfield.TextInputLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:hint="Notes"
                android:layout_marginBottom="24dp"
                style="@style/Widget.Material3.TextInputLayout.OutlinedBox">
                <com.google.android.material.textfield.TextInputEditText
                    android:id="@+id/etNotes"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:gravity="top"
                    android:minLines="3"
                    android:maxLines="5"
                    android:inputType="textMultiLine" />
            </com.google.android.material.textfield.TextInputLayout>

            <com.google.android.material.card.MaterialCardView
                android:id="@+id/wikiCard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="24dp"
                app:cardCornerRadius="16dp"
                app:cardElevation="2dp"
                app:strokeWidth="0dp"
                app:cardBackgroundColor="?attr/colorSurface">
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">
                    <ImageView
                        android:id="@+id/ivWikiImage"
                        android:layout_width="match_parent"
                        android:layout_height="180dp"
                        android:scaleType="centerCrop"/>
                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="vertical"
                        android:padding="20dp">
                        <TextView
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Reference Information"
                            android:textSize="14sp"
                            android:textStyle="bold"
                            android:textColor="@color/pastel_slate_blue" />
                        <TextView
                            android:id="@+id/tvWikiSummary"
                            android:layout_width="match_parent"
                            android:layout_height="wrap_content"
                            android:layout_marginTop="8dp"
                            android:textColor="#444444"
                            android:textSize="15sp"
                            android:lineSpacingMultiplier="1.2"/>
                        <TextView
                            android:id="@+id/btnWikiSource"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:text="Source: Wikipedia"
                            android:textColor="@color/pastel_slate_blue"
                            android:textStyle="bold"
                            android:layout_marginTop="12dp"
                            android:textSize="12sp"/>
                    </LinearLayout>
                </LinearLayout>
            </com.google.android.material.card.MaterialCardView>

            <Button
                android:id="@+id/btnDeleteCollection"
                style="@style/Widget.Material3.Button.TonalButton"
                app:backgroundTint="#FFEBEB"
                android:layout_width="match_parent"
                android:layout_height="56dp"
                android:text="Delete from Collection"
                android:textColor="#D32F2F"
                app:icon="@android:drawable/ic_menu_delete"
                app:iconTint="#D32F2F"
                android:visibility="gone" />
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:background="?attr/colorSurface"
        android:orientation="horizontal"
        android:paddingHorizontal="16dp"
        android:paddingTop="16dp"
        android:paddingBottom="24dp"
        android:elevation="16dp">
        <Button
            android:id="@+id/btnPrimary"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Save Plant"
            android:textColor="#333333"
            app:backgroundTint="@color/pastel_accent_yellow"
            android:layout_marginEnd="8dp"/>
        <Button
            android:id="@+id/btnSecondary"
            style="@style/Widget.Material3.Button.OutlinedButton"
            android:layout_width="0dp"
            android:layout_height="56dp"
            android:layout_weight="1"
            android:text="Discard"
            app:strokeColor="@color/pastel_slate_blue"
            android:textColor="@color/pastel_slate_blue"
            android:layout_ someStart="8dp"/>
    </LinearLayout>
</androidx.coordinatorlayout.widget.CoordinatorLayout>